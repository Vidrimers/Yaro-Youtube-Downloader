# Telegram Bot Configuration
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: Whitelist пользователей (через запятую)
# Если не указано, бот доступен всем
# ALLOWED_USERS=123456789,987654321

# Optional: Максимальная длительность видео в секундах
# Если не указано, ограничения нет
# MAX_VIDEO_DURATION=3600

# Environment
NODE_ENV=production

# Rate Limiting Configuration
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MS=60000

# yt-dlp Timeout Configuration (в миллисекундах)
YTDLP_METADATA_TIMEOUT=30000
YTDLP_URL_TIMEOUT=15000

# File Management Configuration
# Директория для временных файлов
TEMP_DIR=./temp

# Максимальный размер файла для Telegram (в байтах, по умолчанию 2GB)
MAX_FILE_SIZE=2147483648

# Timeout для скачивания видео (в миллисекундах, по умолчанию 10 минут)
DOWNLOAD_TIMEOUT=600000

# Timeout для объединения видео и аудио (в миллисекундах, по умолчанию 5 минут)
MERGE_TIMEOUT=300000

# Интервал очистки старых файлов (в миллисекундах, по умолчанию 1 час)
CLEANUP_INTERVAL=3600000

# Максимальный возраст файла перед удалением (в миллисекундах, по умолчанию 2 часа)
FILE_MAX_AGE=7200000

# File Server Configuration (для больших файлов)
# Порт HTTP сервера для раздачи файлов
FILE_SERVER_PORT=3001

# Базовый URL сервера (если не указан, используется http://localhost:PORT)
# Укажите публичный URL если бот на сервере, например: https://yourdomain.com
# FILE_SERVER_BASE_URL=http://localhost:3001

# Время жизни больших файлов на сервере (в минутах, по умолчанию 10)
LARGE_FILE_TTL_MINUTES=10

# Лимит размера файла для попытки загрузки в Telegram (в байтах, по умолчанию 500MB)
# Файлы больше этого размера сразу отправляются через файловый сервер
TELEGRAM_UPLOAD_LIMIT=524288000

# Timeout для загрузки файлов в Telegram (в миллисекундах, по умолчанию 10 минут)
# Увеличьте если загрузка больших файлов прерывается по таймауту
TELEGRAM_UPLOAD_TIMEOUT=600000

# File Server - управление ресурсами
# Максимальное количество файлов на сервере одновременно (по умолчанию 50)
MAX_CONCURRENT_FILES=50

# Автоудаление файла после успешного скачивания (по умолчанию true)
AUTO_DELETE_AFTER_DOWNLOAD=true

# Минимум свободного места на диске в GB (по умолчанию 5)
# Если места меньше, новые файлы не будут создаваться
MIN_FREE_SPACE_GB=5

# SponsorBlock Configuration
# URL SponsorBlock API (по умолчанию https://sponsor.ajay.app)
# SPONSORBLOCK_API_URL=https://sponsor.ajay.app

# Включить SponsorBlock интеграцию (по умолчанию true)
# SPONSORBLOCK_ENABLED=true
